[Unit]
Description=Comfy Service
After=network.target

[Service]
Type=simple
User=user
Group=comfy
WorkingDirectory=/home/user/comfy

ExecStart=/bin/bash -lc 'cd /home/user/comfy && source venv/bin/activate && comfy launch'
Restart=always
Environment=NODE_ENV=production

[Install]
WantedBy=multi-user.target
